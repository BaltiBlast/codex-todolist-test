<section>
  <h1>Connexion</h1>
  <form method="post" action="#">
    <label for="email">Adresse email</label>
    <input
      type="email"
      id="email"
      name="email"
      autocomplete="email"
      required
    />

    <label for="password">Mot de passe</label>
    <input
      type="password"
      id="password"
      name="password"
      autocomplete="current-password"
      required
    />

    <button type="submit">Se connecter</button>
  </form>
</section>
